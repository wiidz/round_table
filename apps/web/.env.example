# Web dev / preview — copy to apps/web/.env.local or set in repo deploy/.env
#
# Vite reads deploy/.env first, then apps/web/.env* (local overrides win).

# Principal UI dev & preview listen port (vite dev + vite preview)
ROUND_TABLE_WEB_PORT=5173

# Vite listen address — default true (0.0.0.0). Use 127.0.0.1 if Clash fake-ip shows 198.18.x.x.
# ROUND_TABLE_WEB_HOST=127.0.0.1

# Backend API port on host — used for /api proxy when ROUND_TABLE_API_PROXY is unset
ROUND_TABLE_HTTP_PORT=7777

# Optional full API origin for Vite proxy (overrides ROUND_TABLE_HTTP_PORT)
# ROUND_TABLE_API_PROXY=http://127.0.0.1:7777

# Browser-facing API base (build-time; default /api via same-origin proxy)
# VITE_API_BASE=/api
