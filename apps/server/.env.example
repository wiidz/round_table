# Copy to .env for local secrets and overrides (gitignored).
# Priority: server.yaml < .env < process environment variables.
#
# Non-secrets (optional overrides)
ROUND_TABLE_ADDR=:7777
# ROUND_TABLE_STORAGE_DRIVER=memory
# ROUND_TABLE_STORAGE_SQLITE_PATH=./data/roundtable.db

# Secrets — never commit .env
# ROUND_TABLE_DATABASE_DSN=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL_NAME=deepseek-chat

# Discord bot (transport) — create at https://discord.com/developers/applications
# Enable Message Content Intent in the Bot settings.
DISCORD_BOT_TOKEN=
# ROUND_TABLE_DISCORD_GUILD_ID=

# Optional: local proxy for discord.com (make run-discord sets these automatically)
# https_proxy=http://127.0.0.1:7897
# http_proxy=http://127.0.0.1:7897
# all_proxy=socks5://127.0.0.1:7897
