# Copy to deploy/sync-data.env (gitignored) and fill in your values.
#
#   cp deploy/sync-data.env.example deploy/sync-data.env

# SSH target (required)
SYNC_HOST=user@your-server

# Remote RoundTable repo root (required)
SYNC_REMOTE_ROOT=/path/to/round_table

# Optional: extra ssh options (must be quoted if multiple tokens)
SYNC_SSH_OPTS="-p 22"

# Optional: SSH password — avoids repeated prompts (uses sshpass; file is gitignored).
# 更推荐 ssh-copy-id 配置密钥免密，不要把密码提交到 git。
# SYNC_SSH_PASSWORD="your-password"

# Optional: set to 1 to rsync --delete (mirror; removes files missing on source)
# SYNC_DELETE=0
