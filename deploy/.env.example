# Copy to deploy/.env (single secrets file for local dev + docker compose):
#   cp deploy/.env.example deploy/.env
#
# Docker Compose 使用 network_mode: host — 容器与宿主机共享网络，127.0.0.1 即 ShellCrash。
# Discord Transport 由 roundtable-server 内 Supervisor 自动拉起（ROUND_TABLE_DISCORD_AUTO_START）。

# --- Required ---

DEEPSEEK_API_KEY=sk-...

# Discord Bot Token：在 Web 设置 → IM → Discord 配置（SQLite app_settings）。
# 首次启动若下方仍保留旧变量，会自动导入 SQLite：
# DISCORD_BOT_TOKEN=...
# DISCORD_BOT_TOKEN_DESIGNER=

# Restrict bot to one Discord server (recommended in production)
# ROUND_TABLE_DISCORD_GUILD_ID=

# --- ShellCrash mixed-port 4567（host 网络模式：用 127.0.0.1）---

http_proxy=http://USER:PASS@127.0.0.1:4567
https_proxy=http://USER:PASS@127.0.0.1:4567
HTTP_PROXY=http://USER:PASS@127.0.0.1:4567
HTTPS_PROXY=http://USER:PASS@127.0.0.1:4567

# 无 ShellCrash 认证时可省略 USER:PASS@

# 仅宿主机 shell 执行 docker build 时（拉基础镜像）
# HTTP_PROXY=http://127.0.0.1:4567
# HTTPS_PROXY=http://127.0.0.1:4567

# ROUND_TABLE_STORAGE_DRIVER=sqlite
# ROUND_TABLE_STORAGE_SQLITE_PATH=./data/roundtable.db

# --- Optional overrides ---

# --- Ports ---
#
# Docker (host 网络)：ROUND_TABLE_ADDR 即宿主机监听地址；未设时 entrypoint 用 HTTP_PORT → WEB_PORT → 7777。
# 本地 Vite（make web-dev）：Web 走 ROUND_TABLE_WEB_PORT，/api 代理到 ROUND_TABLE_HTTP_PORT。

# ROUND_TABLE_ADDR=:7777
# ROUND_TABLE_HTTP_PORT=7777
# ROUND_TABLE_WEB_PORT=5173   # 勿用 6666 — Chrome 会报 ERR_UNSAFE_PORT
# ROUND_TABLE_DISCORD_AUTO_START=true   # compose 默认 true；本地 server-dev 可在 Web 设置里开关
# ROUND_TABLE_STORAGE_DRIVER=sqlite
# ROUND_TABLE_STORAGE_SQLITE_PATH=./data/roundtable.db
# DEEPSEEK_MODEL_NAME=deepseek-chat
