# Copy to repo root as `.env` for docker compose:
#   cp deploy/.env.example .env
#
# Priority: server.yaml < .env < compose environment

# --- Required for Discord bot ---

DEEPSEEK_API_KEY=sk-...
DISCORD_BOT_TOKEN=...

# Optional: participant bots (typing + messages under each bot name)
DISCORD_BOT_TOKEN_DESIGNER=
DISCORD_BOT_TOKEN_PLAYER=
DISCORD_BOT_TOKEN_DEV=
DISCORD_BOT_TOKEN_OPS=

# Restrict bot to one Discord server (recommended in production)
# ROUND_TABLE_DISCORD_GUILD_ID=

# --- Optional overrides ---

# DEEPSEEK_MODEL_NAME=deepseek-chat
# ROUND_TABLE_MODEL_BASE_URL=https://api.deepseek.com/v1
# ROUND_TABLE_MODEL_TIMEOUT_SEC=120

# HTTP service port mapping (profile `http` only)
# ROUND_TABLE_HTTP_PORT=7777

# Outbound proxy (if Ubuntu host uses one — remove # and set host IP)
# https_proxy=http://172.17.0.1:7897
# http_proxy=http://172.17.0.1:7897
# all_proxy=socks5://172.17.0.1:7897
